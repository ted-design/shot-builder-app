rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function userClient() {
      return request.auth != null
        ? (request.auth.token.clientId != null
            ? request.auth.token.clientId
            : request.auth.token.orgId)
        : null;
    }

    function clientMatches(pathClient) {
      let clientId = userClient();
      return clientId != null && clientId == pathClient;
    }

    function isAdmin() {
      // Support case variations (Admin, admin, ADMIN)
      let role = request.auth.token.role;
      return request.auth != null &&
        (role == 'admin' || role == 'Admin' || role == 'ADMIN');
    }

    function isProducer() {
      // Support case variations for producer, wardrobe, and warehouse roles
      let role = request.auth.token.role;
      return request.auth != null &&
        (role == 'producer' || role == 'Producer' || role == 'PRODUCER' ||
         role == 'wardrobe' || role == 'Wardrobe' || role == 'WARDROBE' ||
         role == 'warehouse' || role == 'Warehouse' || role == 'WAREHOUSE');
    }

    // Check if the user's global role (from auth custom claims) is in the provided list.
    // Unlike hasProjectRole() which checks per-project membership docs,
    // this checks the org-wide role assigned at signup/invite.
    // Normalizes case variations to lowercase canonical form.
    function hasGlobalRole(roles) {
      let role = request.auth.token.role;
      let normalizedRole = role == 'Producer' ? 'producer'
        : role == 'PRODUCER' ? 'producer'
        : role == 'Wardrobe' ? 'warehouse'
        : role == 'WARDROBE' ? 'warehouse'
        : role == 'wardrobe' ? 'warehouse'
        : role == 'Warehouse' ? 'warehouse'
        : role == 'WAREHOUSE' ? 'warehouse'
        : role == 'Viewer' ? 'viewer'
        : role == 'VIEWER' ? 'viewer'
        : role == 'Crew' ? 'crew'
        : role == 'CREW' ? 'crew'
        : role == 'Admin' ? 'admin'
        : role == 'ADMIN' ? 'admin'
        : role;
      return request.auth != null && roles.hasAny([normalizedRole]);
    }

    // Check if a producer has global access to a project based on its visibility.
    // Producers get automatic access to 'team' visibility projects (the default).
    // Used by project sub-resources that need to look up the parent project's visibility.
    // Firestore caches get() calls within a single request, so repeated calls to the
    // same project doc are efficient.
    function producerCanAccessProject(clientId, projectId) {
      let projectPath = /databases/$(database)/documents/clients/$(clientId)/projects/$(projectId);
      let projectData = get(projectPath).data;
      return hasGlobalRole(['producer']) &&
        (!('visibility' in projectData) || projectData.visibility == 'team');
    }

    function hasProjectRole(projectId, roles) {
      let clientId = userClient();
      let memberPath = /databases/$(database)/documents/clients/$(clientId)/projects/$(projectId)/members/$(request.auth.uid);
      let memberRole = exists(memberPath) ? get(memberPath).data.role : null;
      // Normalize role to lowercase for comparison
      // Both 'wardrobe' and 'warehouse' normalize to canonical 'warehouse' (matching TypeScript Role type)
      let normalizedRole = memberRole == 'Producer' ? 'producer'
        : memberRole == 'PRODUCER' ? 'producer'
        : memberRole == 'Wardrobe' ? 'warehouse'
        : memberRole == 'WARDROBE' ? 'warehouse'
        : memberRole == 'wardrobe' ? 'warehouse'
        : memberRole == 'Warehouse' ? 'warehouse'
        : memberRole == 'WAREHOUSE' ? 'warehouse'
        : memberRole == 'Viewer' ? 'viewer'
        : memberRole == 'VIEWER' ? 'viewer'
        : memberRole == 'Crew' ? 'crew'
        : memberRole == 'CREW' ? 'crew'
        : memberRole;
      return clientId != null &&
        request.auth != null &&
        memberRole != null &&
        roles.hasAny([normalizedRole]);
    }

    function isSystemAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/systemAdmins/$(request.auth.token.email)) &&
        get(/databases/$(database)/documents/systemAdmins/$(request.auth.token.email)).data.enabled == true;
    }

    // Function queue — Firestore-trigger-based Cloud Function invocation
    // Bypasses HTTP/CORS/IAM by using Firestore writes + onCreate trigger
    match /_functionQueue/{docId} {
      // Authenticated users can create requests
      allow create: if request.auth != null
        && request.resource.data.action is string
        && request.resource.data.status == "pending"
        && request.resource.data.createdBy == request.auth.uid;

      // Unauthenticated creates only for publicUpdatePull
      allow create: if request.auth == null
        && request.resource.data.action == "publicUpdatePull"
        && request.resource.data.status == "pending"
        && request.resource.data.createdBy == "anonymous"
        && request.resource.data.data.shareToken is string
        && request.resource.data.data.shareToken.size() >= 8;

      // Authenticated users can read their own queue docs
      allow read: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      // Unauthenticated reads for publicUpdatePull responses (get only — no list/enumeration)
      allow get: if resource.data.action == "publicUpdatePull"
        && resource.data.createdBy == "anonymous";

      // No client-side updates or deletes
      allow update, delete: if false;
    }

    // System Admins - managed via Cloud Functions and admin scripts
    match /systemAdmins/{email} {
      // Only system admins can read the list of system admins
      allow read: if isSystemAdmin();
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // Public pull sharing via collection group queries
    // This wildcard rule allows unauthenticated users to query pulls across all clients/projects
    // when a valid shareToken is provided
    match /{path=**}/pulls/{pullId} {
      // Allow unauthenticated collection group queries when sharing is enabled
      // AND the request includes a shareToken equality filter that matches the document's token.
      // Security: Requires knowledge of the exact cryptographic shareToken.
      // Minimum 8 chars accepts legacy 16-char tokens and newer 32+ char tokens.
      // The client queries: collectionGroup('pulls').where('shareToken', '==', token).where('shareEnabled', '==', true)
      allow list: if resource.data.shareEnabled == true
        && resource.data.shareToken is string
        && resource.data.shareToken.size() >= 8;
      // Direct get requires both shareEnabled and a non-empty shareToken on the document.
      // The caller must already know the document path (unguessable without the token-based list query).
      allow get: if resource.data.shareEnabled == true
        && resource.data.shareToken is string
        && resource.data.shareToken.size() >= 8;
    }

    // Public shot sharing — share docs live at /shotShares/{shareToken} (doc id = token).
    // Resolved shot data is denormalized into the doc at creation time.
    match /shotShares/{shareToken} {
      // Allow unauthenticated get when sharing is enabled and not expired.
      // Security: Requires knowledge of the exact share token (UUID / 32+ chars).
      allow get: if resource.data.enabled == true
        && (resource.data.expiresAt == null || resource.data.expiresAt > request.time);

      // Authenticated admin/producer reads (management UI)
      allow get, list: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        resource.data.clientId == userClient();

      allow create: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        request.resource.data.clientId == userClient() &&
        request.resource.data.projectId is string &&
        (request.resource.data.shotIds == null || request.resource.data.shotIds is list) &&
        request.resource.data.enabled is bool;

      allow update, delete: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        resource.data.clientId == userClient();
    }

    // Public casting sharing — share docs live at /castingShares/{shareToken} (doc id = token).
    // Resolved talent data is denormalized into the doc at creation time.
    // External reviewers submit votes to the votes subcollection without auth.
    match /castingShares/{shareToken} {
      // Allow unauthenticated get when sharing is enabled and not expired.
      // Security: Requires knowledge of the exact share token (UUID / 32+ chars).
      // Note: must check field existence before access — missing fields throw in rules.
      allow get: if resource.data.enabled == true
        && (!('expiresAt' in resource.data) || resource.data.expiresAt == null || resource.data.expiresAt > request.time);

      // Authenticated admin/producer reads (management UI)
      allow get, list: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        resource.data.clientId == userClient();

      allow create: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        request.resource.data.clientId == userClient() &&
        request.resource.data.projectId is string &&
        request.resource.data.enabled is bool;

      allow update, delete: if isAuthed() &&
        (isAdmin() || isProducer()) &&
        resource.data.clientId == userClient();

      // Votes subcollection — unauthenticated reviewers can create/update votes.
      // Doc ID is deterministic: {normalizedEmail}_{talentId} (prevents duplicates).
      // Votes are intentionally visible to all share link viewers (attributed voting).
      match /votes/{voteId} {
        // Unauthenticated vote creation — constrained to allowed fields only.
        allow create: if
          get(/databases/$(database)/documents/castingShares/$(shareToken)).data.enabled == true &&
          (get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt == null ||
           get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt > request.time) &&
          request.resource.data.keys().hasOnly(['reviewerEmail', 'reviewerName', 'talentId', 'decision', 'comment', 'createdAt', 'updatedAt']) &&
          request.resource.data.reviewerEmail is string &&
          request.resource.data.reviewerEmail.size() >= 5 &&
          request.resource.data.reviewerName is string &&
          request.resource.data.reviewerName.size() >= 1 &&
          request.resource.data.talentId is string &&
          request.resource.data.decision in ['approve', 'disapprove', 'maybe', 'withdrawn'] &&
          (request.resource.data.comment == null ||
           (request.resource.data.comment is string && request.resource.data.comment.size() <= 2000));

        // Reviewer can update their own vote (email + talentId + reviewerName immutable).
        allow update: if
          get(/databases/$(database)/documents/castingShares/$(shareToken)).data.enabled == true &&
          (get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt == null ||
           get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt > request.time) &&
          request.resource.data.keys().hasOnly(['reviewerEmail', 'reviewerName', 'talentId', 'decision', 'comment', 'createdAt', 'updatedAt']) &&
          request.resource.data.reviewerEmail == resource.data.reviewerEmail &&
          request.resource.data.reviewerName == resource.data.reviewerName &&
          request.resource.data.talentId == resource.data.talentId &&
          request.resource.data.decision in ['approve', 'disapprove', 'maybe', 'withdrawn'] &&
          (request.resource.data.comment == null ||
           (request.resource.data.comment is string && request.resource.data.comment.size() <= 2000));

        // Unauthenticated list when share is enabled and not expired.
        // Intentionally open: all reviewers' votes are visible (attributed voting model).
        allow list: if
          get(/databases/$(database)/documents/castingShares/$(shareToken)).data.enabled == true &&
          (get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt == null ||
           get(/databases/$(database)/documents/castingShares/$(shareToken)).data.expiresAt > request.time);

        // Authenticated admin/producer can read all votes.
        allow read: if isAuthed() &&
          (isAdmin() || isProducer()) &&
          get(/databases/$(database)/documents/castingShares/$(shareToken)).data.clientId == userClient();

        // Votes are immutable once cast (no delete).
        allow delete: if false;
      }
    }

    // LEGACY COLLECTIONS - DEPRECATED
    // These root-level collections are no longer used in the application.
    // All data has been migrated to client-scoped collections under /clients/{clientId}/
    // Keeping these rules disabled to prevent accidental access to legacy data.
    // If you need to access legacy data for migration, temporarily enable with client matching.

    // match /talent/{docId} {
    //   allow read: if false;  // Explicitly deny all access
    //   allow write: if false;
    // }

    // match /locations/{docId} {
    //   allow read: if false;  // Explicitly deny all access
    //   allow write: if false;
    // }

    // match /shots/{docId} {
    //   allow read: if false;  // Explicitly deny all access
    //   allow write: if false;
    // }

	    match /clients/{clientId}/talent/{docId} {
	      allow read: if clientMatches(clientId);
	      allow create, update, delete: if clientMatches(clientId) && (isAdmin() || isProducer());

      // Versions - immutable document snapshots for version history
      match /versions/{versionId} {
        allow read: if clientMatches(clientId);
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if false; // Versions are immutable
      }

      // Presence - field-level locking for collaborative editing
      match /presence {
        allow read: if clientMatches(clientId);
        allow write: if clientMatches(clientId) && isAuthed();
      }
    }

    match /clients/{clientId}/locations/{docId} {
      allow read: if clientMatches(clientId);
      allow create, update, delete: if clientMatches(clientId) && (isAdmin() || isProducer());

      // Versions - immutable document snapshots for version history
      match /versions/{versionId} {
        allow read: if clientMatches(clientId);
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if false; // Versions are immutable
      }

      // Presence - field-level locking for collaborative editing
      match /presence {
        allow read: if clientMatches(clientId);
        allow write: if clientMatches(clientId) && isAuthed();
	      }
	    }

	    // Crew - org-level crew directory (used by projects for assignments)
	    match /clients/{clientId}/crew/{crewMemberId} {
	      allow read: if clientMatches(clientId) && isAuthed();
	      allow create, update, delete: if clientMatches(clientId) &&
	        (isAdmin() || isProducer());
	    }

	    // Shot Requests - org-level request inbox for producers and admins
	    match /clients/{clientId}/shotRequests/{requestId} {
	      allow read: if clientMatches(clientId) &&
	        (isAdmin() || isProducer());

	      allow create: if clientMatches(clientId) && isAuthed() &&
	        (isAdmin() || isProducer()) &&
	        request.resource.data.submittedBy == request.auth.uid &&
	        request.resource.data.status == 'submitted' &&
	        request.resource.data.title is string &&
	        request.resource.data.title.size() > 0;

	      allow update: if clientMatches(clientId) && isAuthed() &&
	        (isAdmin() || isProducer());

	      allow delete: if clientMatches(clientId) && isAdmin();

	      // Comments on shot requests — visible to admins and producers only
	      match /comments/{commentId} {
	        allow read: if clientMatches(clientId) && (isAdmin() || isProducer());
	        allow create: if clientMatches(clientId) && (isAdmin() || isProducer()) &&
	          request.resource.data.authorId == request.auth.uid &&
	          request.resource.data.body is string &&
	          request.resource.data.body.size() > 0 &&
	          request.resource.data.body.size() <= 5000;
	      }
	    }

	    match /clients/{clientId}/shots/{docId} {
	      allow read: if clientMatches(clientId);
	      allow create, update, delete: if clientMatches(clientId) && isAuthed();

      // Comments - subcollection of shots for collaboration
      match /comments/{commentId} {
        // Anyone with shot read access can read comments
        allow read: if clientMatches(clientId) && isAuthed();

        // Any authenticated client user can create comments
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.createdBy == request.auth.uid;

        // Author or admin can update. Only the deleted flag can change; all other fields are immutable.
        allow update: if clientMatches(clientId) && isAuthed() &&
          (isAdmin() || resource.data.createdBy == request.auth.uid) &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.createdByName == resource.data.createdByName &&
          request.resource.data.createdByAvatar == resource.data.createdByAvatar &&
          request.resource.data.body == resource.data.body;

        // Only comment author can hard-delete their own comment (UI uses soft-delete via update)
        allow delete: if clientMatches(clientId) && isAuthed() &&
          resource.data.createdBy == request.auth.uid;
      }

      // Versions - immutable document snapshots for version history
      match /versions/{versionId} {
        allow read: if clientMatches(clientId);
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if false; // Versions are immutable
      }

      // Presence - field-level locking for collaborative editing
      match /presence {
        allow read: if clientMatches(clientId);
        allow write: if clientMatches(clientId) && isAuthed();
      }
    }

    // Notifications - users can only read/update/delete their own notifications
    match /clients/{clientId}/notifications/{notificationId} {
      allow read: if clientMatches(clientId) && isAuthed() &&
        resource.data.userId == request.auth.uid;
      allow create: if clientMatches(clientId) && isAuthed() &&
        (isAdmin() || isProducer()) &&
        request.resource.data.userId is string;
      allow update, delete: if clientMatches(clientId) && isAuthed() &&
        resource.data.userId == request.auth.uid;
    }

    // User profiles - users can read their own profile and other users in their client
    match /clients/{clientId}/users/{userId} {
      allow read: if clientMatches(clientId) && isAuthed();
      allow create: if clientMatches(clientId) && (isAdmin() || (isAuthed() && request.auth.uid == userId));
      allow update: if clientMatches(clientId) && (isAdmin() || request.auth.uid == userId);
      allow delete: if clientMatches(clientId) && isAdmin();
    }

    // Pending invitations — admin-only management, Cloud Functions handle claims
    match /clients/{clientId}/pendingInvitations/{invitationId} {
      allow read: if clientMatches(clientId) && isAdmin();
      allow create, update, delete: if clientMatches(clientId) && isAdmin();
    }

    // Wildcard rule for client-scoped collections
    // Restricts read access to admin users only to prevent unauthorized data access
    // Specific collections have more granular rules defined below
    match /clients/{clientId}/{document=**} {
      allow read: if clientMatches(clientId) && isAdmin();
    }

    match /clients/{clientId}/products/{productId} {
      allow read: if clientMatches(clientId);
      allow create, delete: if clientMatches(clientId) && isAdmin();
      allow update: if clientMatches(clientId) &&
        (isAdmin() || isProducer());
    }

    match /clients/{clientId}/productFamilies/{familyId} {
      allow read: if clientMatches(clientId);
      allow create, update: if clientMatches(clientId) && (isAdmin() || isProducer());
      allow delete: if clientMatches(clientId) && isAdmin();

      match /skus/{skuId} {
        allow read: if clientMatches(clientId);
        allow create, update: if clientMatches(clientId) && (isAdmin() || isProducer());
        allow delete: if clientMatches(clientId) && isAdmin();
      }

      // Samples - supply tracking (shoot / pre-production / bulk)
      match /samples/{sampleId} {
        allow read: if clientMatches(clientId) && isAuthed();
        allow create, update, delete: if clientMatches(clientId) && (isAdmin() || isProducer());
      }

      // Documents - tech packs, spec sheets, supporting materials
      match /documents/{documentId} {
        allow read: if clientMatches(clientId) && isAuthed();
        allow create, update, delete: if clientMatches(clientId) && (isAdmin() || isProducer());
      }

      // Comments - discussion thread on a product family
      // Admin override on create: allows comment transfer during product merge
      match /comments/{commentId} {
        allow read: if clientMatches(clientId) && isAuthed();

        allow create: if clientMatches(clientId) && isAuthed() &&
          (request.resource.data.createdBy == request.auth.uid || isAdmin());

        // Author or admin can update. Only the deleted flag can change; all other fields are immutable.
        allow update: if clientMatches(clientId) && isAuthed() &&
          (isAdmin() || resource.data.createdBy == request.auth.uid) &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.createdByName == resource.data.createdByName &&
          request.resource.data.createdByAvatar == resource.data.createdByAvatar &&
          request.resource.data.body == resource.data.body;

        // Allow hard delete by the author (UI uses soft-delete via update).
        allow delete: if clientMatches(clientId) && isAuthed() &&
          resource.data.createdBy == request.auth.uid;
      }

      // Versions - immutable document snapshots for version history
      match /versions/{versionId} {
        allow read: if clientMatches(clientId);
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if false; // Versions are immutable
      }

      // Presence - field-level locking for collaborative editing
      match /presence {
        allow read: if clientMatches(clientId);
        allow write: if clientMatches(clientId) && isAuthed();
      }
    }

    // Color swatches - org-level palette for standardizing product colors
    match /clients/{clientId}/colorSwatches/{swatchId} {
      allow read: if clientMatches(clientId);
      allow create, update: if clientMatches(clientId) && (isAdmin() || isProducer());
      allow delete: if clientMatches(clientId) && isAdmin();
    }

    // Product classifications - org-level taxonomy for product type/subcategory controls
    match /clients/{clientId}/productClassifications/{classificationId} {
      allow read: if clientMatches(clientId);
      allow create, update: if clientMatches(clientId) && (isAdmin() || isProducer());
      allow delete: if clientMatches(clientId) && isAdmin();
    }

    // Export templates - workspace-level shared PDF builder templates
    match /clients/{clientId}/exportTemplates/{templateId} {
      allow read: if clientMatches(clientId) && (isAdmin() || isProducer());
      allow create: if clientMatches(clientId) &&
        (isAdmin() || isProducer()) &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if clientMatches(clientId) &&
        (isAdmin() || isProducer()) &&
        request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if clientMatches(clientId) &&
        (isAdmin() || isProducer());
    }

	    match /clients/{clientId}/projects/{projectId} {
        // --- Project Visibility Model ---
        // Projects have an optional 'visibility' field: 'team' (default), 'private', or 'restricted'.
        // - 'team' (or unset): All producers in the org can read/write. No membership doc needed.
        // - 'private': Only the creator (createdBy) and admins can access.
        // - 'restricted': Only explicit project members (via /members subcollection) can access.
        // Admins always have full access regardless of visibility.

        // Read: split into list (collection query) vs get (single document) to avoid
        // Firestore denying entire list queries when any document fails per-document checks.
        //
        // List: admins and producers can list all projects in their org.
        // Producers need to see all projects on the dashboard — visibility is enforced
        // on sub-resources (shots, pulls, schedules) and on writes, not on listing.
        // Other roles need explicit project membership to see a project in lists.
        allow list: if clientMatches(clientId) && (
          isAdmin() ||
          hasGlobalRole(['producer']) ||
          hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer'])
        );

        // Get: individual document access applies full visibility rules.
        allow get: if clientMatches(clientId) && (
          isAdmin() ||
          // Producers can read any team-visible project (default when field absent)
          (hasGlobalRole(['producer']) &&
            (!('visibility' in resource.data) || resource.data.visibility == 'team')) ||
          // Private projects: creator only (plus admins above)
          (resource.data.visibility == 'private' && resource.data.createdBy == request.auth.uid) ||
          // Restricted or any role with explicit membership
          hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer'])
        );

        // Create: admins and producers can create projects
        // Note: resource.data doesn't exist for creates, use request.resource.data
	      allow create: if clientMatches(clientId) && (isAdmin() || isProducer());

        // Update: admins, producers on team-visible projects, private project creators, or members
	      allow update: if clientMatches(clientId) && (
          isAdmin() ||
          // Producers can update team-visible projects
          (hasGlobalRole(['producer']) &&
            (!('visibility' in resource.data) || resource.data.visibility == 'team')) ||
          // Private projects: creator can update
          (resource.data.visibility == 'private' && resource.data.createdBy == request.auth.uid) ||
          // Explicit project membership
          hasProjectRole(projectId, ['producer', 'warehouse'])
        );

        // Delete: admins, producers on team-visible projects, private project creators
        allow delete: if clientMatches(clientId) && (
          isAdmin() ||
          (hasGlobalRole(['producer']) &&
            (!('visibility' in resource.data) || resource.data.visibility == 'team')) ||
          (resource.data.visibility == 'private' && resource.data.createdBy == request.auth.uid) ||
          hasProjectRole(projectId, ['producer', 'warehouse'])
        );

        // Project members — per-project access control
        // Explicit rules prevent the wildcard catch-all from granting non-admin writes
        match /members/{memberId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() ||
            producerCanAccessProject(clientId, projectId) ||
            hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          // Admin-only member management
          allow create, update, delete: if clientMatches(clientId) && isAdmin();
          // Self-membership: allow producers to add themselves when creating a project.
          // Validates: own UID only, must set addedBy to self, role must be 'producer',
          // and only the expected fields are written (no extra data injection).
          allow create: if clientMatches(clientId)
            && isProducer()
            && memberId == request.auth.uid
            && request.resource.data.addedBy == request.auth.uid
            && request.resource.data.role == 'producer'
            && request.resource.data.keys().hasOnly(['role', 'addedAt', 'addedBy']);
        }

	      // Project departments and positions (project-scoped role taxonomy)
	      match /departments/{departmentId} {
	        allow read: if clientMatches(clientId) &&
	          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
	           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
	        allow create, update, delete: if clientMatches(clientId) &&
	          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
	           hasProjectRole(projectId, ['producer', 'warehouse']));

	        match /positions/{positionId} {
	          allow read: if clientMatches(clientId) &&
	            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
	             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
	          allow create, update, delete: if clientMatches(clientId) &&
	            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
	             hasProjectRole(projectId, ['producer', 'warehouse']));
	        }
	      }

	      // Pulls - project-specific access for authenticated users
	      // Public sharing is handled by the top-level wildcard rule
	      match /pulls/{pullId} {
	        // All project members can read pulls
	        allow read: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
	        // Only producers and warehouse can write pulls (not crew/viewer)
	        allow create, update, delete: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'warehouse']));
      }

      // Activities - project activity feed with 90-day retention
      match /activities/{activityId} {
        // Anyone with project read access can read activities
        allow read: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));

        // Authenticated users with project access can create activities
        // Validate that actorId matches authenticated user
        allow create: if clientMatches(clientId) && isAuthed() &&
          request.resource.data.actorId == request.auth.uid &&
          request.resource.data.projectId == projectId;

        // Activities are immutable - no updates allowed (audit trail integrity)
        allow update: if false;

        // Only admins can delete activities (for cleanup/retention purposes)
        allow delete: if clientMatches(clientId) && isAdmin();
      }

      // Schedules - call sheet scheduling for projects
      match /schedules/{scheduleId} {
        // Anyone with project access can read schedules
        allow read: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));

        // Producers and above can create/update schedules
        allow create, update: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'warehouse']));

        // Only admins can delete schedules
        allow delete: if clientMatches(clientId) && isAdmin();

        // Schedule entries - individual items on the schedule
        match /entries/{entryId} {
          // Anyone with project access can read entries
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));

          // Producers and above can create/update/delete entries
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }

        // Day details - call times, notes, weather (per schedule)
        match /dayDetails/{detailId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }

        // Talent call overrides (per schedule)
        match /talentCalls/{talentId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }

        // Crew call overrides (per schedule)
        match /crewCalls/{crewMemberId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }

        // Client call rows (per schedule)
        match /clientCalls/{clientCallId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }

        // Call sheet builder state (config/layout/templates) for a schedule.
        match /callSheet/{docId} {
          allow read: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
          allow create, update, delete: if clientMatches(clientId) &&
            (isAdmin() || producerCanAccessProject(clientId, projectId) ||
             hasProjectRole(projectId, ['producer', 'warehouse']));
        }
      }

      // Export reports — saved PDF builder documents per project
      match /exportReports/{reportId} {
        allow read: if clientMatches(clientId) &&
          (isAdmin() || isProducer());
        allow create: if clientMatches(clientId) &&
          (isAdmin() || isProducer()) &&
          request.resource.data.createdBy == request.auth.uid;
        allow update: if clientMatches(clientId) &&
          (isAdmin() || isProducer()) &&
          request.resource.data.createdBy == resource.data.createdBy;
        allow delete: if clientMatches(clientId) &&
          (isAdmin() || isProducer());
      }

      // Lanes (Scenes) — explicit rule with size validation on direction/notes
      // and positive-integer validation on sceneNumber. Must come BEFORE the
      // wildcard catch-all so it takes precedence.
      match /lanes/{laneId} {
        allow read: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
        allow create, update: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'warehouse'])) &&
          (
            !('direction' in request.resource.data) ||
            request.resource.data.direction == null ||
            (request.resource.data.direction is string && request.resource.data.direction.size() <= 500)
          ) &&
          (
            !('notes' in request.resource.data) ||
            request.resource.data.notes == null ||
            (request.resource.data.notes is string && request.resource.data.notes.size() <= 5000)
          ) &&
          (
            !('sceneNumber' in request.resource.data) ||
            request.resource.data.sceneNumber == null ||
            (
              request.resource.data.sceneNumber is int &&
              request.resource.data.sceneNumber >= 1 &&
              request.resource.data.sceneNumber <= 9999
            )
          );
        allow delete: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'warehouse']));
      }

      // Wildcard catch-all for any other project sub-collections
      // Includes 'crew' for consistency with explicit sub-resource rules above.
      match /{collectionId}/{docId} {
        allow read: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'crew', 'warehouse', 'viewer']));
        allow create, update, delete: if clientMatches(clientId) &&
          (isAdmin() || producerCanAccessProject(clientId, projectId) ||
           hasProjectRole(projectId, ['producer', 'warehouse']));
      }
    }
  }
}
